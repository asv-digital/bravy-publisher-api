# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/publicacao_bravy

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=publicacao-renders

# Anthropic (Claude API)
ANTHROPIC_API_KEY=

# JWT — generate with: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# OAuth token encryption — base64 of 32 random bytes
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Optional: override datasets directory (defaults to ./datasets)
# DATASET_DIR=/abs/path/to/dataset

# Meta Business Login (Instagram OAuth)
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=http://localhost:3001/api/v1/oauth/instagram/callback

# Frontend URL — used by OAuth callback redirect and CORS
FRONTEND_URL=http://localhost:3000
# Comma-separated extra origins for CORS (optional, falls back to FRONTEND_URL)
# CORS_ORIGINS=https://app.example.com,https://staging.example.com

# App
PORT=3001
NODE_ENV=development
